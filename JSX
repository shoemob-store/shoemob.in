// ─── ROOT ─────────────────────────────────────────────────────────────────────
export default function App() {
  const [page, setPage] = useState("home");
  useEffect(()=>{
    const link = document.createElement("link");
    link.rel = "stylesheet";
    link.href = "https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700;9..40,800;9..40,900&display=swap";
    document.head.appendChild(link);
    const style = document.createElement("style");
    style.textContent = `
      * { scrollbar-width: thin; scrollbar-color: #CCCCCC #F5F5F5; }
      *::-webkit-scrollbar { width: 6px; }
      *::-webkit-scrollbar-track { background: #F5F5F5; }
      *::-webkit-scrollbar-thumb { background: #CCCCCC; border-radius: 3px; }
      select option { background: #FFFFFF !important; color: #111111 !important; }
    `;
    document.head.appendChild(style);
  },[]);

  const renderPage = () => {
    if(typeof page==="object"){
      if(page.name==="product")      return <ProductDetail productId={page.id} setPage={setPage} />;
      if(page.name==="orderSuccess") return <OrderSuccessPage orderId={page.orderId} setPage={setPage} />;
    }
    switch(page){
      case "home":     return <HomePage setPage={setPage} />;
      case "shop":     return <ShopPage setPage={setPage} />;
      case "wishlist": return <WishlistPage setPage={setPage} />;
      case "cart":     return <CartPage setPage={setPage} />;
      case "checkout": return <CheckoutPage setPage={setPage} />;
      case "admin":    return <AdminPage setPage={setPage} />;
      case "about":    return <AboutPage setPage={setPage} />;
      default:         return <HomePage setPage={setPage} />;
    }
  };

  return (
    <StoreProvider>
      <div style={gs.page}>
        <Navbar page={typeof page==="string"?page:page.name} setPage={setPage} />
        {renderPage()}
        <footer style={{ borderTop:`1px solid ${THEME.border}`, padding:"38px 28px", marginTop:60, background:THEME.surface }}>
          <div style={{ maxWidth:1400, margin:"0 auto", display:"flex", justifyContent:"space-between", alignItems:"center", flexWrap:"wrap", gap:16 }}>
            <div>
              <div style={{ fontFamily:"'Bebas Neue',sans-serif", fontSize:"1.9rem", background:THEME.gradientAccent, WebkitBackgroundClip:"text", WebkitTextFillColor:"transparent", letterSpacing:"0.14em" }}>VYROX</div>
              <div style={{ fontSize:"0.67rem", color:THEME.textDim, letterSpacing:"0.1em", marginTop:2 }}>PREMIUM FASHION & LIFESTYLE</div>
            </div>
            <div style={{ display:"flex", gap:24 }}>
              {["home","shop","about"].map(p=><button key={p} onClick={()=>setPage(p)} style={{ background:"none", border:"none", color:THEME.textDim, cursor:"pointer", fontSize:"0.72rem", textTransform:"uppercase", letterSpacing:"0.1em" }}>{p}</button>)}
            </div>
            <div style={{ fontSize:"0.67rem", color:THEME.textDim }}>© 2026 VYROX. ALL RIGHTS RESERVED.</div>
          </div>
        </footer>
      </div>
    </StoreProvider>
  );
}
