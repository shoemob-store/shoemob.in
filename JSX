  return (
    <div style={{ ...gs.card, ...gs.glow, padding:28, marginBottom:24 }}>
      <div style={{ fontFamily:"'Bebas Neue',sans-serif", fontSize:"1.1rem", letterSpacing:"0.1em", marginBottom:22, background:THEME.gradientAccent, WebkitBackgroundClip:"text", WebkitTextFillColor:"transparent" }}>{initial?"EDIT PRODUCT":"ADD PRODUCT"}</div>
      <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:14 }}>
        {[["name","Product Name"],["price","Price (₹)"],["discountPrice","Discount Price (₹)"],["stock","Stock"],["sku","SKU"],["emoji","Emoji"]].map(([field,label])=>(
          <div key={field}><label style={{ fontSize:"0.67rem", textTransform:"uppercase", color:THEME.textMuted, display:"block", marginBottom:5, letterSpacing:"0.08em" }}>{label}</label><input value={form[field]} onChange={e=>f(field,e.target.value)} style={gs.input} placeholder={label} /></div>
        ))}
        <div style={{ gridColumn:"1 / -1" }}>
          <label style={{ fontSize:"0.67rem", textTransform:"uppercase", color:THEME.textMuted, display:"block", marginBottom:5 }}>Category</label>
          <select value={form.category} onChange={e=>f("category",e.target.value)} style={gs.input}>{CATEGORIES.filter(c=>c!=="All").map(c=><option key={c} value={c}>{c}</option>)}</select>
        </div>
        <div style={{ gridColumn:"1 / -1" }}>
          <label style={{ fontSize:"0.67rem", textTransform:"uppercase", color:THEME.textMuted, display:"block", marginBottom:5 }}>Description</label>
          <textarea value={form.description} onChange={e=>f("description",e.target.value)} style={{ ...gs.input, height:80, resize:"vertical" }} />
        </div>
        <div>
          <label style={{ fontSize:"0.67rem", textTransform:"uppercase", color:THEME.textMuted, display:"block", marginBottom:8 }}>Sizes</label>
          <div style={{ display:"flex", flexWrap:"wrap", gap:6 }}>{SIZES.map(s=><button key={s} type="button" onClick={()=>tog("sizes",s)} style={{ ...gs.btnGhost, padding:"5px 11px", fontSize:"0.72rem", borderColor:form.sizes.includes(s)?THEME.accent:THEME.border, color:form.sizes.includes(s)?"#FFFFFF":THEME.textMuted, background:form.sizes.includes(s)?"#111111":"transparent" }}>{s}</button>)}</div>
        </div>
        <div>
          <label style={{ fontSize:"0.67rem", textTransform:"uppercase", color:THEME.textMuted, display:"block", marginBottom:8 }}>Colors</label>
          <div style={{ display:"flex", flexWrap:"wrap", gap:6 }}>{COLORS.map(c=><button key={c} type="button" onClick={()=>tog("colors",c)} style={{ ...gs.btnGhost, padding:"5px 11px", fontSize:"0.72rem", borderColor:form.colors.includes(c)?THEME.accent:THEME.border, color:form.colors.includes(c)?"#FFFFFF":THEME.textMuted, background:form.colors.includes(c)?"#111111":"transparent" }}>{c}</button>)}</div>
        </div>
        <div style={{ display:"flex", gap:20 }}>
          <label style={{ display:"flex", alignItems:"center", gap:8, cursor:"pointer", fontSize:"0.78rem", color:THEME.textMuted }}><input type="checkbox" checked={form.bestseller} onChange={e=>f("bestseller",e.target.checked)} style={{ accentColor:THEME.accentBold }} /> Bestseller</label>
          <label style={{ display:"flex", alignItems:"center", gap:8, cursor:"pointer", fontSize:"0.78rem", color:THEME.textMuted }}><input type="checkbox" checked={form.featured} onChange={e=>f("featured",e.target.checked)} style={{ accentColor:THEME.accentBold }} /> Featured</label>
        </div>
      </div>
      <div style={{ display:"flex", gap:12, marginTop:22 }}>
        <button onClick={()=>onSave({...form,price:+form.price,discountPrice:form.discountPrice?+form.discountPrice:null,stock:+form.stock})} style={gs.btn}>{initial?"SAVE CHANGES":"ADD PRODUCT"}</button>
        <button onClick={onCancel} style={gs.btnGhost}>Cancel</button>
      </div>
    </div>
  );
}

