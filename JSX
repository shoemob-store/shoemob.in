// ─── SHOP ─────────────────────────────────────────────────────────────────────
function ShopPage({ setPage }) {
  const { products } = useStore();
  const [search, setSearch]       = useState("");
  const [debSearch, setDebSearch] = useState("");
  const [category, setCategory]   = useState("All");
  const [sortBy, setSortBy]       = useState("newest");
  const [priceMax, setPriceMax]   = useState(10000);
  const [filterSize, setFSize]    = useState("");
  const [filterColor, setFColor]  = useState("");
  const [inStock, setInStock]     = useState(false);
  const [showF, setShowF]         = useState(true);
  const debRef = useRef(null);
  const handleSearch = v => { setSearch(v); clearTimeout(debRef.current); debRef.current=setTimeout(()=>setDebSearch(v),350); };
  const clearAll = () => { setCategory("All");setSortBy("newest");setPriceMax(10000);setFSize("");setFColor("");setInStock(false);setSearch("");setDebSearch(""); };
  const filtered = products
    .filter(p => {
      if(category!=="All"&&p.category!==category) return false;
      if(inStock&&p.stock===0) return false;
      if(filterSize&&!p.sizes.includes(filterSize)) return false;
      if(filterColor&&!p.colors.includes(filterColor)) return false;
      if((p.discountPrice||p.price)>priceMax) return false;
      if(debSearch){const q=debSearch.toLowerCase();return p.name.toLowerCase().includes(q)||p.category.toLowerCase().includes(q)||p.description.toLowerCase().includes(q);}
      return true;
    })
    .sort((a,b)=>{
      if(sortBy==="price_asc")  return (a.discountPrice||a.price)-(b.discountPrice||b.price);
      if(sortBy==="price_desc") return (b.discountPrice||b.price)-(a.discountPrice||a.price);
      if(sortBy==="name")       return a.name.localeCompare(b.name);
      if(sortBy==="rating")     return b.rating-a.rating;
      return 0;
    });
  return (
    <div style={{ maxWidth:1400, margin:"0 auto", padding:"36px 28px", display:"flex", gap:28 }}>
      {showF && (
        <div style={{ width:252, flexShrink:0 }}>
          <div style={{ ...gs.card, ...gs.glow, padding:22, position:"sticky", top:82 }}>
            <div style={{ display:"flex", justifyContent:"space-between", marginBottom:20 }}>
              <span style={{ fontFamily:"'Bebas Neue',sans-serif", letterSpacing:"0.12em", fontSize:"1.1rem", background:THEME.gradientAccent, WebkitBackgroundClip:"text", WebkitTextFillColor:"transparent" }}>FILTERS</span>
              <button onClick={clearAll} style={{ background:"none", border:"none", color:THEME.gold, cursor:"pointer", fontSize:"0.72rem", textTransform:"uppercase", letterSpacing:"0.06em" }}>Clear All</button>
            </div>
            <FSection label="Category">
              <div style={{ display:"flex", flexDirection:"column", gap:3, maxHeight:232, overflowY:"auto" }}>
                {CATEGORIES.map(c=>(
                  <button key={c} onClick={()=>setCategory(c)} style={{ background:category===c?"#111111":"none", color:category===c?THEME.accent:THEME.textMuted, border:category===c?`1px solid rgba(0,0,0,0.27)`:"1px solid transparent", cursor:"pointer", textAlign:"left", padding:"6px 10px", fontSize:"0.78rem", fontWeight:category===c?700:400, borderRadius:5, transition:"all 0.15s" }}>{c}</button>
                ))}
              </div>
            </FSection>
            <FSection label="Price Range">
              <div style={{ fontSize:"0.78rem", color:THEME.gold, marginBottom:8, fontWeight:700 }}>Up to {fmt(priceMax)}</div>
              <input type="range" min={500} max={10000} step={100} value={priceMax} onChange={e=>setPriceMax(+e.target.value)} style={{ width:"100%", accentColor:THEME.accentBold }} />
            </FSection>
            <FSection label="Size">
              <div style={{ display:"flex", flexWrap:"wrap", gap:6 }}>
                {SIZES.map(s=><button key={s} onClick={()=>setFSize(filterSize===s?"":s)} style={{ ...gs.btnGhost, padding:"5px 11px", fontSize:"0.72rem", borderColor:filterSize===s?THEME.accent:THEME.border, color:filterSize===s?THEME.accent:THEME.textMuted, background:filterSize===s?"rgba(0,0,0,0.05)":"transparent" }}>{s}</button>)}
              </div>
            </FSection>
            <FSection label="Color">
              <div style={{ display:"flex", flexWrap:"wrap", gap:6 }}>
                {COLORS.slice(0,6).map(c=><button key={c} onClick={()=>setFColor(filterColor===c?"":c)} style={{ ...gs.btnGhost, padding:"5px 11px", fontSize:"0.72rem", borderColor:filterColor===c?THEME.accent:THEME.border, color:filterColor===c?THEME.accent:THEME.textMuted, background:filterColor===c?"rgba(0,0,0,0.05)":"transparent" }}>{c}</button>)}
              </div>
            </FSection>
            <FSection label="Availability">
              <label style={{ display:"flex", alignItems:"center", gap:8, cursor:"pointer", fontSize:"0.78rem", color:THEME.textMuted }}>
                <input type="checkbox" checked={inStock} onChange={e=>setInStock(e.target.checked)} style={{ accentColor:THEME.accentBold }} /> In Stock Only
              </label>
            </FSection>
          </div>
        </div>
      )}
      <div style={{ flex:1, minWidth:0 }}>
        <div style={{ display:"flex", gap:12, marginBottom:24, flexWrap:"wrap" }}>
          <input value={search} onChange={e=>handleSearch(e.target.value)} placeholder="🔍  Search products..." style={{ ...gs.input, flex:1, minWidth:200 }} />
          <select value={sortBy} onChange={e=>setSortBy(e.target.value)} style={{ ...gs.input, width:195 }}>
            <option value="newest">Newest First</option>
            <option value="price_asc">Price: Low → High</option>
            <option value="price_desc">Price: High → Low</option>
            <option value="name">Name A–Z</option>
            <option value="rating">Highest Rated</option>
          </select>
          <button onClick={()=>setShowF(!showF)} style={gs.btnGhost}>{showF?"Hide":"Show"} Filters</button>
        </div>
        <div style={{ fontSize:"0.78rem", color:THEME.textMuted, marginBottom:20 }}>
          Showing <strong style={{ color:THEME.accent }}>{filtered.length}</strong> products {category!=="All"&&`in ${category}`}
        </div>
        {filtered.length===0 ? (
          <div style={{ textAlign:"center", padding:"80px 20px" }}>
            <div style={{ fontSize:"3rem", marginBottom:16 }}>🔍</div>
            <div style={{ fontFamily:"'Bebas Neue',sans-serif", fontSize:"1.6rem", color:THEME.textMuted, marginBottom:16 }}>No Products Found</div>
            <button onClick={clearAll} style={gs.btn}>Clear Filters</button>
          </div>
        ) : (
          <div style={{ display:"grid", gridTemplateColumns:"repeat(auto-fill,minmax(228px,1fr))", gap:20 }}>
            {filtered.map(p=><ProductCard key={p.id} product={p} setPage={setPage} />)}
          </div>
        )}
      </div>
    </div>
  );
}
