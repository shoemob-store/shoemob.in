// ─── STATE ────────────────────────────────────────────────────────────────────
const StoreContext = createContext(null);
function useLocalStorage(key, initial) {
  const [val, setVal] = useState(() => { try { const s = localStorage.getItem(key); return s ? JSON.parse(s) : initial; } catch { return initial; } });
  const set = useCallback((v) => { setVal(v); try { localStorage.setItem(key, JSON.stringify(v)); } catch {} }, [key]);
  return [val, set];
}
function StoreProvider({ children }) {
  const [cart, setCart]         = useLocalStorage("vyrox_cart", []);
  const [wishlist, setWishlist] = useLocalStorage("vyrox_wishlist", []);
  const [orders, setOrders]     = useLocalStorage("vyrox_orders", []);
  const [products, setProducts] = useState(MOCK_PRODUCTS);
  const [adminAuth, setAdminAuth] = useState(() => { try { return !!localStorage.getItem("vyrox_admin"); } catch { return false; } });
  const addToCart = (product, size, color, qty=1) => setCart(prev => { const key=`${product.id}_${size}_${color}`; const ex=prev.find(i=>`${i.id}_${i.size}_${i.color}`===key); if(ex) return prev.map(i=>`${i.id}_${i.size}_${i.color}`===key?{...i,qty:i.qty+qty}:i); return [...prev,{...product,size,color,qty}]; });
  const removeFromCart = (id,size,color) => setCart(prev=>prev.filter(i=>!(i.id===id&&i.size===size&&i.color===color)));
  const updateQty = (id,size,color,qty) => { if(qty<1) return removeFromCart(id,size,color); setCart(prev=>prev.map(i=>i.id===id&&i.size===size&&i.color===color?{...i,qty}:i)); };
  const clearCart = () => setCart([]);
  const toggleWishlist = (id) => setWishlist(prev=>prev.includes(id)?prev.filter(w=>w!==id):[...prev,id]);
  const cartTotal = cart.reduce((s,i)=>s+(i.discountPrice||i.price)*i.qty,0);
  const cartCount = cart.reduce((s,i)=>s+i.qty,0);
  const adminLogin = (user,pass) => { if(user==="vyrox"&&pass==="#vyrox2026"){localStorage.setItem("vyrox_admin","1");setAdminAuth(true);return true;}return false; };
  const adminLogout = () => { localStorage.removeItem("vyrox_admin");setAdminAuth(false); };
  const addProduct = (p) => setProducts(prev=>[{...p,id:Date.now().toString(),rating:0,reviewsCount:0,createdAt:new Date().toISOString()},...prev]);
  const editProduct = (id,data) => setProducts(prev=>prev.map(p=>p.id===id?{...p,...data}:p));
  const deleteProduct = (id) => setProducts(prev=>prev.filter(p=>p.id!==id));
  const placeOrder = (details) => { const orderId=`VYX-${Math.floor(1000+Math.random()*9000)}`; const order={orderId,products:cart,total:cartTotal,customer:details,status:"Pending",createdAt:new Date().toISOString()}; setOrders(prev=>[order,...prev]); clearCart(); return order; };
  const updateOrderStatus = (orderId,status) => setOrders(prev=>prev.map(o=>o.orderId===orderId?{...o,status}:o));
  return <StoreContext.Provider value={{cart,wishlist,orders,products,adminAuth,cartTotal,cartCount,addToCart,removeFromCart,updateQty,clearCart,toggleWishlist,adminLogin,adminLogout,addProduct,editProduct,deleteProduct,placeOrder,updateOrderStatus}}>{children}</StoreContext.Provider>;
}
const useStore = () => useContext(StoreContext);

