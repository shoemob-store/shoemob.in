// ─── CHECKOUT ─────────────────────────────────────────────────────────────────
function CheckoutPage({ setPage }) {
  const { cart, cartTotal, placeOrder } = useStore();
  const [form, setForm]   = useState({ name:"", phone:"", email:"", address:"", city:"", state:"", zip:"" });
  const [errors, setErrors] = useState({});
  const validate = () => {
    const e={};
    if(!form.name.trim()) e.name="Name is required";
    if(!/^[6-9]\d{9}$/.test(form.phone)) e.phone="Valid 10-digit Indian phone required";
    if(!/\S+@\S+\.\S+/.test(form.email)) e.email="Valid email required";
    if(!form.address.trim()) e.address="Address is required";
    if(!form.city.trim()) e.city="City is required";
    if(!form.state.trim()) e.state="State is required";
    if(!/^\d{6}$/.test(form.zip)) e.zip="Valid 6-digit PIN required";
    return e;
  };
  const handleWA = () => {
    const e=validate();
    if(Object.keys(e).length){setErrors(e);return;}
    const order=placeOrder(form);
    const items=cart.map(i=>`• ${i.name} | ${i.size} | ${i.color} | Qty: ${i.qty}`).join("\n");
    const total=cartTotal>=2999?cartTotal:cartTotal+99;
    const msg=`🛒 *New Order - VYROX*\nOrder ID: *${order.orderId}*\n\n*Products:*\n${items}\n\n*Total: ₹${total.toLocaleString("en-IN")}*\n\n*Customer Details:*\nName: ${form.name}\nPhone: ${form.phone}\nAddress: ${form.address}, ${form.city}, ${form.state} - ${form.zip}`;
    window.open(`https://wa.me/918320471216?text=${encodeURIComponent(msg)}`,"_blank");
    setPage({name:"orderSuccess",orderId:order.orderId});
  };
  if(cart.length===0) return <div style={{ textAlign:"center", padding:80, color:THEME.textMuted }}>Cart is empty. <button onClick={()=>setPage("shop")} style={gs.btn}>Shop</button></div>;
  return (
    <div style={{ maxWidth:920, margin:"0 auto", padding:"44px 28px" }}>
      <div style={{ fontFamily:"'Bebas Neue',sans-serif", fontSize:"2.5rem", letterSpacing:"0.08em", marginBottom:32, background:THEME.gradientAccent, WebkitBackgroundClip:"text", WebkitTextFillColor:"transparent", display:"inline-block" }}>CHECKOUT</div>
      <div style={{ display:"grid", gridTemplateColumns:"1fr 320px", gap:28 }}>
        <div style={{ ...gs.card, padding:30 }}>
          <div style={{ fontFamily:"'Bebas Neue',sans-serif", fontSize:"1.1rem", letterSpacing:"0.1em", marginBottom:22, color:THEME.accent }}>DELIVERY DETAILS</div>
          <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:14 }}>
            {[["name","Full Name","text"],["phone","Phone Number","tel"],["email","Email Address","email"],["address","Street Address","text"],["city","City","text"],["state","State","text"],["zip","PIN Code","text"]].map(([field,label,type])=>(
              <div key={field} style={{ gridColumn:field==="address"?"1 / -1":"auto" }}>
                <label style={{ display:"block", fontSize:"0.67rem", textTransform:"uppercase", letterSpacing:"0.1em", color:THEME.textMuted, marginBottom:6 }}>{label}</label>
                <input type={type} value={form[field]} onChange={e=>setForm({...form,[field]:e.target.value})} style={{ ...gs.input, borderColor:errors[field]?THEME.error:THEME.border }} placeholder={label} />
                {errors[field] && <div style={{ fontSize:"0.65rem", color:THEME.error, marginTop:4 }}>{errors[field]}</div>}
              </div>
            ))}
          </div>
        </div>
        <div style={{ ...gs.card, ...gs.glow, padding:26, height:"fit-content" }}>
          <div style={{ fontFamily:"'Bebas Neue',sans-serif", fontSize:"1.1rem", letterSpacing:"0.1em", marginBottom:16, background:THEME.gradientAccent, WebkitBackgroundClip:"text", WebkitTextFillColor:"transparent" }}>ORDER SUMMARY</div>
          {cart.map((item,i)=><div key={i} style={{ display:"flex", justifyContent:"space-between", fontSize:"0.76rem", color:THEME.textMuted, marginBottom:6 }}><span>{item.name} ×{item.qty}</span><span>{fmt((item.discountPrice||item.price)*item.qty)}</span></div>)}
          <div style={{ borderTop:`1px solid ${THEME.border}`, marginTop:14, paddingTop:14 }}>
            <div style={{ display:"flex", justifyContent:"space-between", fontWeight:800, marginBottom:22 }}>
              <span>Total</span>
              <span style={{ background:THEME.gradientGold, WebkitBackgroundClip:"text", WebkitTextFillColor:"transparent" }}>{fmt(cartTotal>=2999?cartTotal:cartTotal+99)}</span>
            </div>
          </div>
          <button onClick={handleWA} style={{ background:"linear-gradient(135deg,#25D366 0%,#128C7E 100%)", color:"#fff", border:"none", borderRadius:6, width:"100%", padding:"14px", fontWeight:800, cursor:"pointer", fontSize:"0.88rem", letterSpacing:"0.06em", textTransform:"uppercase", boxShadow:"0 4px 20px rgba(37,211,102,0.4)", display:"flex", alignItems:"center", justifyContent:"center", gap:8 }}>
            <span style={{ fontSize:"1.2rem" }}>💬</span> ORDER VIA WHATSAPP
          </button>
          <div style={{ fontSize:"0.65rem", color:THEME.textDim, marginTop:10, textAlign:"center" }}>You'll be redirected to WhatsApp to confirm.</div>
        </div>
      </div>
    </div>
  );
}

