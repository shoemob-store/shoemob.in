function StatusBadge({ status }) {
  const map = { Pending:["#FBBF24","#78350F"], Confirmed:["#60A5FA","#1E3A5F"], Shipped:["#C084FC","#3B0764"], Delivered:["#34D399","#064E3B"] };
  const [fg] = map[status]||[THEME.textMuted];
  return <span style={{ background:`${fg}22`, color:fg, padding:"4px 12px", fontSize:"0.64rem", textTransform:"uppercase", letterSpacing:"0.1em", border:`1px solid ${fg}44`, borderRadius:"100px", fontWeight:700 }}>{status}</span>;
}

